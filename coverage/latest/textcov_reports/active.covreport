   76|      2|static bool os_supports_avx512(uint64_t xcr0) {
   77|       |#if defined(OPENSSL_APPLE)
   78|       |  // The Darwin kernel had a bug where it could corrupt the opmask registers.
   79|       |  // See
   80|       |  // https://community.intel.com/t5/Software-Tuning-Performance/MacOS-Darwin-kernel-bug-clobbers-AVX-512-opmask-register-state/m-p/1327259
   81|       |  // Darwin also does not initially set the XCR0 bits for AVX512, but they are
   82|       |  // set if the thread tries to use AVX512 anyway.  Thus, to safely and
   83|       |  // consistently use AVX512 on macOS we'd need to check the kernel version as
   84|       |  // well as detect AVX512 support using a macOS-specific method.  We don't
   85|       |  // bother with this, especially given Apple's transition to arm64.
   86|       |  return false;
   87|       |#else
   88|      2|  return (xcr0 & 0xe6) == 0xe6;
   89|      2|#endif
