   79|       |        // which allows “socket hijacking”, so we explicitly don't set it here.
   80|       |        // https://docs.microsoft.com/en-us/windows/win32/winsock/using-so-reuseaddr-and-so-exclusiveaddruse
   81|       |        #[cfg(not(windows))]
