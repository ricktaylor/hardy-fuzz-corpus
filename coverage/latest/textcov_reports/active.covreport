 1384|     13|fn translate_position(input: &[u8], index: usize) -> (usize, usize) {
 1385|     13|    if input.is_empty() {
 1386|      0|        return (0, index);
 1387|     13|    }
 1388|       |
 1389|     13|    let safe_index = index.min(input.len() - 1);
 1390|     13|    let column_offset = index - safe_index;
 1391|     13|    let index = safe_index;
 1392|       |
 1393|     13|    let nl = input[0..index]
 1394|     13|        .iter()
 1395|     13|        .rev()
 1396|     13|        .enumerate()
 1397|     13|        .find(|(_, b)| **b == b'\n')
 1398|     13|        .map(|(nl, _)| index - nl - 1);
 1399|     13|    let line_start = match nl {
 1400|      0|        Some(nl) => nl + 1,
 1401|     13|        None => 0,
 1402|       |    };
 1403|     13|    let line = input[0..line_start].iter().filter(|b| **b == b'\n').count();
 1404|       |
 1405|       |    // HACK: This treats byte offset and column offsets the same
 1406|     13|    let column = core::str::from_utf8(&input[line_start..=index])
 1407|     13|        .map(|s| s.chars().count() - 1)
 1408|     13|        .unwrap_or_else(|_| index - line_start);
 1409|     13|    let column = column + column_offset;
 1410|       |
 1411|     13|    (line, column)
 1412|     13|}
