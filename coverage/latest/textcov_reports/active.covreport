  204|       |    // this is both faster than sorting the labels and feasible in `const`. We use an ADD chain
  205|       |    // as opposed to an XOR chain to avoid duplicate labels cancelling out.
  206|    175|    let mut i = 0;
  207|    175|    let labels = labels.as_const_slice();
  208|    350|    while i < labels.len() {
  209|    175|        let label_hash = hash_label(&labels[i]);
  210|    175|        hash = hash.wrapping_add(label_hash);
  211|    175|        i += 1;
  212|    175|    }
  213|       |
  214|    175|    hash
  215|    175|}

