   70|      1|        let original =
   71|      1|            ManuallyDrop::new(unsafe { std::os::unix::net::UnixStream::from_raw_fd(receiver_fd) });
   72|      1|        let mut receiver = UnixStream::from_std(original.try_clone()?);
   73|       |
   74|      1|        io_handle.register_signal_receiver(&mut receiver)?;
   75|       |
   76|      1|        Ok(Self {
   77|      1|            io,
   78|      1|            receiver,
   79|      1|            inner: Arc::new(()),
   80|      1|        })
   81|      1|    }
