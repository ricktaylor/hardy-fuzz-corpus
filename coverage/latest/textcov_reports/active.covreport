  151|   173k|    pub(super) fn transition_to_idle(&self) -> TransitionToIdle {
  152|   173k|        self.fetch_update_action(|curr| {
  153|       |            assert!(curr.is_running());
  154|       |
  155|       |            if curr.is_cancelled() {
  156|       |                return (TransitionToIdle::Cancelled, None);
  157|       |            }
  158|       |
