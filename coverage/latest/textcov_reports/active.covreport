  105|  3.60k|    fn process(&mut self) {
  106|       |        // If the signal pipe has not received a readiness event, then there is
  107|       |        // nothing else to do.
  108|  3.60k|        if !self.io.consume_signal_ready() {
  109|  3.60k|            return;
  110|      0|        }
  111|       |
  112|       |        // Drain the pipe completely so we can receive a new readiness event
  113|       |        // if another signal has come in.
  114|      0|        let mut buf = [0; 128];
  115|       |        #[allow(clippy::unused_io_amount)]
  116|       |        loop {
  117|      0|            match self.receiver.read(&mut buf) {
  118|      0|                Ok(0) => panic!("EOF on self-pipe"),
  119|      0|                Ok(_) => continue, // Keep reading
  120|      0|                Err(e) if e.kind() == std_io::ErrorKind::WouldBlock => break,
  121|      0|                Err(e) => panic!("Bad read on self-pipe: {e}"),
  122|       |            }
  123|       |        }
  124|       |
  125|       |        // Broadcast any signals which were received
  126|      0|        globals().broadcast();
  127|  3.60k|    }

