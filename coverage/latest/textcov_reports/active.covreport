  234|       |            unsafe { f(recorder.as_ref()) }
  235|       |        } else if let Some(global_recorder) = GLOBAL_RECORDER.try_load() {
  236|       |            f(global_recorder)
  237|       |        } else {
  238|       |            f(&NOOP_RECORDER)
  239|       |        }
  240|       |    })
