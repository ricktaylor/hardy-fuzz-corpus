   84|      1|fn pair<T>(flags: libc::c_int) -> io::Result<(T, T)>
   85|      1|where
   86|      1|    T: FromRawFd,
   87|       |{
   88|       |    #[cfg(not(any(
   89|       |        target_os = "aix",
   90|       |        target_os = "haiku",
   91|       |        target_os = "ios",
   92|       |        target_os = "macos",
   93|       |        target_os = "nto",
   94|       |        target_os = "tvos",
   95|       |        target_os = "visionos",
   96|       |        target_os = "watchos",
   97|       |        target_os = "espidf",
   98|       |        target_os = "vita",
   99|       |        target_os = "horizon",
  100|       |    )))]
  101|      1|    let flags = flags | libc::SOCK_NONBLOCK | libc::SOCK_CLOEXEC;
  102|       |
  103|      1|    let mut fds = [-1; 2];
  104|      1|    syscall!(socketpair(libc::AF_UNIX, flags, 0, fds.as_mut_ptr()))?;
  105|      1|    let pair = unsafe { (T::from_raw_fd(fds[0]), T::from_raw_fd(fds[1])) };
  106|       |
  107|       |    // Darwin (and others) doesn't have SOCK_NONBLOCK or SOCK_CLOEXEC.
  108|       |    //
  109|       |    // In order to set those flags, additional `fcntl` sys calls must be
  110|       |    // performed. If a `fnctl` fails after the sockets have been created,
  111|       |    // the file descriptors will leak. Creating `pair` above ensures that if
  112|       |    // there is an error, the file descriptors are closed.
  113|       |    #[cfg(any(
  114|       |        target_os = "aix",
  115|       |        target_os = "haiku",
  116|       |        target_os = "ios",
  117|       |        target_os = "macos",
  118|       |        target_os = "nto",
  119|       |        target_os = "tvos",
  120|       |        target_os = "visionos",
  121|       |        target_os = "watchos",
  122|       |        target_os = "espidf",
  123|       |        target_os = "vita",
  124|       |        target_os = "horizon"
  125|       |    ))]
  126|       |    {
  127|       |        syscall!(fcntl(fds[0], libc::F_SETFL, libc::O_NONBLOCK))?;
  128|       |        #[cfg(not(any(target_os = "espidf", target_os = "vita", target_os = "nto")))]
  129|       |        syscall!(fcntl(fds[0], libc::F_SETFD, libc::FD_CLOEXEC))?;
  130|       |        syscall!(fcntl(fds[1], libc::F_SETFL, libc::O_NONBLOCK))?;
  131|       |        #[cfg(not(any(target_os = "espidf", target_os = "vita", target_os = "nto")))]
  132|       |        syscall!(fcntl(fds[1], libc::F_SETFD, libc::FD_CLOEXEC))?;
  133|       |    }
  134|       |
  135|      1|    Ok(pair)
  136|      1|}

