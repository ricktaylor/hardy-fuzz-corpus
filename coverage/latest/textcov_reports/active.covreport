  377|  1.56k|                INITIAL_STATE,
  378|  1.56k|                (INITIAL_STATE - REF_ONE) & !JOIN_INTEREST,
  379|  1.56k|                Release,
  380|  1.56k|                Relaxed,
  381|  1.56k|            )
  382|  1.56k|            .map(|_| ())
  383|  1.56k|            .map_err(|_| ())
