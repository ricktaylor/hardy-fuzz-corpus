   94|       |        target_os = "haiku",
   95|       |        target_os = "ios",
   96|       |        target_os = "macos",
   97|       |        target_os = "redox",
   98|       |        target_os = "tvos",
   99|       |        target_os = "visionos",
  100|       |        target_os = "watchos",
  101|       |        target_os = "espidf",
  102|       |        target_os = "vita",
  103|       |        target_os = "hermit",
  104|       |        target_os = "nto",
  105|       |        target_os = "wasi",
  106|       |        target_os = "horizon",
  107|       |        all(target_arch = "x86", target_os = "android"),
  108|       |    ))]
