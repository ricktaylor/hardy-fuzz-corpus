_RNvMNtNtCs8KEr2bUmOCV_5tokio7runtime7builderNtB2_7Builder39build_current_thread_runtime_components:
 1664|      1|    fn build_current_thread_runtime_components(
 1665|      1|        &mut self,
 1666|      1|        local_tid: Option<ThreadId>,
 1667|      1|    ) -> io::Result<(CurrentThread, Handle, BlockingPool)> {
 1668|       |        use crate::runtime::scheduler;
 1669|       |        use crate::runtime::Config;
 1670|       |
 1671|      1|        let mut cfg = self.get_cfg();
 1672|      1|        cfg.timer_flavor = TimerFlavor::Traditional;
 1673|      1|        let (driver, driver_handle) = driver::Driver::new(cfg)?;
 1674|       |
 1675|       |        // Blocking pool
 1676|      1|        let blocking_pool = blocking::create_blocking_pool(self, self.max_blocking_threads);
 1677|      1|        let blocking_spawner = blocking_pool.spawner().clone();
 1678|       |
 1679|       |        // Generate a rng seed for this runtime.
 1680|      1|        let seed_generator_1 = self.seed_generator.next_generator();
 1681|      1|        let seed_generator_2 = self.seed_generator.next_generator();
 1682|       |
 1683|       |        // And now put a single-threaded scheduler on top of the timer. When
 1684|       |        // there are no futures ready to do something, it'll let the timer or
 1685|       |        // the reactor to generate some new stimuli for the futures to continue
 1686|       |        // in their life.
 1687|      1|        let (scheduler, handle) = CurrentThread::new(
 1688|      1|            driver,
 1689|      1|            driver_handle,
 1690|      1|            blocking_spawner,
 1691|      1|            seed_generator_2,
 1692|      1|            Config {
 1693|      1|                before_park: self.before_park.clone(),
 1694|      1|                after_unpark: self.after_unpark.clone(),
 1695|      1|                before_spawn: self.before_spawn.clone(),
 1696|      1|                #[cfg(tokio_unstable)]
 1697|      1|                before_poll: self.before_poll.clone(),
 1698|      1|                #[cfg(tokio_unstable)]
 1699|      1|                after_poll: self.after_poll.clone(),
 1700|      1|                after_termination: self.after_termination.clone(),
 1701|      1|                global_queue_interval: self.global_queue_interval,
 1702|      1|                event_interval: self.event_interval,
 1703|      1|                #[cfg(tokio_unstable)]
 1704|      1|                unhandled_panic: self.unhandled_panic.clone(),
 1705|      1|                disable_lifo_slot: self.disable_lifo_slot,
 1706|      1|                // This setting never makes sense for a current thread runtime,
 1707|      1|                // as it only configures how the I/O driver is stolen across
 1708|      1|                // workers.
 1709|      1|                enable_eager_driver_handoff: false,
 1710|      1|                seed_generator: seed_generator_1,
 1711|      1|                metrics_poll_count_histogram: self.metrics_poll_count_histogram_builder(),
 1712|      1|            },
 1713|      1|            local_tid,
 1714|      1|            self.name.clone(),
 1715|      1|        );
 1716|       |
 1717|      1|        let handle = Handle {
 1718|      1|            inner: scheduler::Handle::CurrentThread(handle),
 1719|      1|        };
