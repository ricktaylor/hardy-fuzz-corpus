  313|  1.62k|    pub(crate) fn take_waker(&self) -> Option<Waker> {
  314|       |        // AcqRel ordering is used in order to acquire the value of the `waker`
  315|       |        // cell as well as to establish a `release` ordering with whatever
  316|       |        // memory the `AtomicWaker` is associated with.
  317|  1.62k|        match self.state.fetch_or(WAKING, AcqRel) {
  318|       |            WAITING => {
  319|       |                // SAFETY: the waking lock has been acquired.
  320|  1.62k|                let waker = unsafe { self.waker.with_mut(|t| (*t).take()) };
  321|       |
  322|       |                // Release the lock.
  323|  1.62k|                let old_state = self.state.swap(WAITING, Release);
  324|  1.62k|                debug_assert!(old_state == WAKING);
  325|       |
  326|  1.62k|                waker
  327|       |            }
  328|      0|            state => {
  329|       |                // There is a concurrent thread currently updating the
  330|       |                // associated waker.
  331|       |                //
  332|       |                // Nothing more to do as the `WAKING` bit has been set. It
  333|       |                // doesn't matter if there are concurrent registering threads or
  334|       |                // not.
  335|       |                //
  336|      0|                debug_assert!(
  337|      0|                    state == REGISTERING || state == REGISTERING | WAKING || state == WAKING
  338|       |                );
  339|      0|                None
  340|       |            }
  341|       |        }
  342|  1.62k|    }
