   88|      0|            20
   89|      1|        } else if cfg!(target_os = "haiku") {
   90|      0|            32
   91|       |        } else {
   92|      1|            128
   93|       |        };
   94|      1|        listen(&listener.inner, backlog)?;
   95|      1|        Ok(listener)
   96|      1|    }
