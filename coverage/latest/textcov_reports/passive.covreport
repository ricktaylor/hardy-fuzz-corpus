   87|       |{
   88|       |    #[cfg(not(any(
   89|       |        target_os = "aix",
   90|       |        target_os = "haiku",
   91|       |        target_os = "ios",
   92|       |        target_os = "macos",
   93|       |        target_os = "nto",
   94|       |        target_os = "tvos",
   95|       |        target_os = "visionos",
   96|       |        target_os = "watchos",
   97|       |        target_os = "espidf",
   98|       |        target_os = "vita",
   99|       |        target_os = "horizon",
  100|       |    )))]
