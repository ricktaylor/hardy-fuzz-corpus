   40|    427|async fn run_iteration(data: &[u8]) {
   41|       |    // Connect to the listener, retrying briefly if it's not ready yet
   42|    427|    let mut stream = None;
   43|    427|    for _ in 0..10 {
   44|    428|        match tokio::net::TcpStream::connect(fuzz_addr()).await {
   45|    427|            Ok(s) => {
   46|    427|                stream = Some(s);
   47|    427|                break;
   48|       |            }
   49|      1|            Err(e) if e.kind() == std::io::ErrorKind::ConnectionRefused => {
   50|      1|                tokio::time::sleep(tokio::time::Duration::from_millis(100)).await;
   51|       |            }
   52|      0|            Err(e) => panic!("failed to connect: {e}"),
   53|       |        }
   54|       |    }
   55|    427|    let stream = stream.expect("failed to connect to listener after retries");
   56|    427|    let (mut rx, mut tx) = stream.into_split();
   57|       |
   58|       |    // Drain any responses from the server in the background
   59|    427|    let drain = tokio::task::spawn(async move {
   60|       |        let mut buf = [0u8; 4096];
   61|       |        loop {
   62|       |            match rx.read(&mut buf).await {
   63|       |                Ok(0) | Err(_) => break,
   64|       |                _ => {}
   65|       |            }
   66|       |        }
   67|       |    });
   68|       |
   69|       |    // Write fuzz data and close
   70|    427|    let _ = tx.write_all(data).await;
   71|    427|    let _ = tx.shutdown().await;
   72|       |
   73|       |    // Wait for server to close its side
   74|    427|    let _ = drain.await;
   75|    427|}
