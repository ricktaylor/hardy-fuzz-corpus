   88|      0|            20
   89|      0|        } else if cfg!(target_os = "haiku") {
   90|      0|            32
   91|       |        } else {
   92|      0|            128
   93|       |        };
   94|      0|        listen(&listener.inner, backlog)?;
   95|      0|        Ok(listener)
