   15|    419|pub(crate) fn new_socket(domain: libc::c_int, socket_type: libc::c_int) -> io::Result<libc::c_int> {
   16|       |    #[cfg(any(
   17|       |        target_os = "android",
   18|       |        target_os = "dragonfly",
   19|       |        target_os = "freebsd",
   20|       |        target_os = "hurd",
   21|       |        target_os = "illumos",
   22|       |        target_os = "linux",
   23|       |        target_os = "netbsd",
   24|       |        target_os = "openbsd",
   25|       |        target_os = "solaris",
   26|       |        target_os = "hermit",
   27|       |        target_os = "cygwin",
