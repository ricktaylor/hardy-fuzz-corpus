 1404|       |
 1405|       |    // HACK: This treats byte offset and column offsets the same
 1406|     13|    let column = core::str::from_utf8(&input[line_start..=index])
 1407|     13|        .map(|s| s.chars().count() - 1)
 1408|     13|        .unwrap_or_else(|_| index - line_start);
 1409|     13|    let column = column + column_offset;
 1410|       |
 1411|     13|    (line, column)
 1412|     13|}
