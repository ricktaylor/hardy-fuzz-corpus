 1388|       |
 1389|     13|    let safe_index = index.min(input.len() - 1);
 1390|     13|    let column_offset = index - safe_index;
 1391|     13|    let index = safe_index;
 1392|       |
 1393|     13|    let nl = input[0..index]
 1394|     13|        .iter()
 1395|     13|        .rev()
