  131|      6|pub(crate) fn complete_quads_len(
  132|      6|    input: &[u8],
  133|      6|    input_len_rem: usize,
  134|      6|    output_len: usize,
  135|      6|    decode_table: &[u8; 256],
  136|      6|) -> Result<usize, DecodeSliceError> {
  137|      6|    debug_assert!(input.len() % 4 == input_len_rem);
  138|       |
