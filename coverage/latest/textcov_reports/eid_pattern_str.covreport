 1384|      2|fn translate_position(input: &[u8], index: usize) -> (usize, usize) {
 1385|      2|    if input.is_empty() {
 1386|      0|        return (0, index);
 1387|      2|    }
 1388|       |
 1389|      2|    let safe_index = index.min(input.len() - 1);
 1390|      2|    let column_offset = index - safe_index;
 1391|      2|    let index = safe_index;
 1392|       |
 1393|      2|    let nl = input[0..index]
 1394|      2|        .iter()
 1395|      2|        .rev()
 1396|      2|        .enumerate()
 1397|      2|        .find(|(_, b)| **b == b'\n')
 1398|      2|        .map(|(nl, _)| index - nl - 1);
 1399|      2|    let line_start = match nl {
 1400|      0|        Some(nl) => nl + 1,
 1401|      2|        None => 0,
 1402|       |    };
 1403|      2|    let line = input[0..line_start].iter().filter(|b| **b == b'\n').count();
 1404|       |
 1405|       |    // HACK: This treats byte offset and column offsets the same
 1406|      2|    let column = core::str::from_utf8(&input[line_start..=index])
 1407|      2|        .map(|s| s.chars().count() - 1)
 1408|      2|        .unwrap_or_else(|_| index - line_start);
 1409|      2|    let column = column + column_offset;
 1410|       |
 1411|      2|    (line, column)
 1412|      2|}
