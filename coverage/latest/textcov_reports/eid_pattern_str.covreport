  359|  4.16k|fn parse_ipn_range(input: &mut &str) -> ModalResult<IpnPattern> {
  360|  4.16k|    delimited("[", separated(1.., parse_ipn_interval, ","), "]")
  361|  4.16k|        .map(|mut intervals: Vec<RangeInclusive<u32>>| {
  362|       |            if intervals.is_empty() {
  363|       |                IpnPattern::Range(Vec::new())
  364|       |            } else {
  365|       |                // 1. Sort the ranges by their start value.
  366|       |                intervals.sort_by_key(|r| *r.start());
  367|       |
  368|       |                // 2. Merge them into a new vector (at most as many as input intervals).
  369|       |                let mut merged = Vec::with_capacity(intervals.len());
  370|       |                let mut current_interval = intervals.remove(0);
  371|       |
  372|       |                for next_interval in intervals {
  373|       |                    // Check if the next range is adjacent or overlapping.
  374|       |                    // The `+ 1` handles adjacency, e.g., `1..=5` and `6..=10`.
  375|       |                    if *next_interval.start() <= current_interval.end().saturating_add(1) {
  376|       |                        // If so, extend the current range to encompass the next one.
  377|       |                        current_interval = *current_interval.start()
  378|       |                            ..=*current_interval.end().max(next_interval.end());
  379|       |                    } else {
  380|       |                        // Otherwise, the current range is finished. Push it to the results
  381|       |                        // and start a new current range.
  382|       |                        if current_interval.end() == current_interval.start() {
  383|       |                            merged.push(IpnInterval::Number(*current_interval.start()));
  384|       |                        } else {
  385|       |                            merged.push(IpnInterval::Range(current_interval));
  386|       |                        }
  387|       |                        current_interval = next_interval;
  388|       |                    }
  389|       |                }
  390|       |                // Add the last processed range.
  391|       |                if current_interval.end() == current_interval.start() {
  392|       |                    merged.push(IpnInterval::Number(*current_interval.start()));
  393|       |                } else {
  394|       |                    merged.push(IpnInterval::Range(current_interval));
  395|       |                }
  396|       |                IpnPattern::Range(merged)
  397|       |            }
  398|       |        })
  399|  4.16k|        .parse_next(input)
  400|  4.16k|}
