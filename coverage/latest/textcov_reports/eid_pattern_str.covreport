 1407|      2|        .map(|s| s.chars().count() - 1)
 1408|      2|        .unwrap_or_else(|_| index - line_start);
 1409|      2|    let column = column + column_offset;
 1410|       |
 1411|      2|    (line, column)
 1412|      2|}
