  104|      1|pub fn init(pkg_name: &'static str, pkg_ver: &'static str, level: tracing::Level) -> OtelGuard {
  105|       |    // Create a filter using RUST_LOG if set, falling back to the configured level
  106|      1|    let make_filter = || {
  107|       |        EnvFilter::builder()
  108|       |            .with_default_directive(
  109|       |                tracing_subscriber::filter::LevelFilter::from_level(level).into(),
  110|       |            )
  111|       |            .from_env_lossy()
  112|       |    };
  113|       |
  114|      1|    let resource = Resource::builder()
  115|      1|        .with_service_name(pkg_name)
  116|      1|        .with_schema_url([KeyValue::new(SERVICE_VERSION, pkg_ver)], SCHEMA_URL)
  117|      1|        .build();
  118|       |
  119|      1|    let tracer_provider = init_tracer(&resource);
  120|      1|    let meter_provider = init_metrics(&resource, pkg_name);
  121|      1|    let logger_provider = init_logs(&resource);
  122|       |
  123|       |    // Create a new OpenTelemetryTracingBridge using the above LoggerProvider.
  124|      1|    let otel_layer =
  125|      1|        opentelemetry_appender_tracing::layer::OpenTelemetryTracingBridge::new(&logger_provider);
  126|       |
  127|       |    // To prevent a telemetry-induced-telemetry loop, OpenTelemetry's own internal
  128|       |    // logging is properly suppressed. However, logs emitted by external components
  129|       |    // (such as reqwest, tonic, etc.) are not suppressed as they do not propagate
  130|       |    // OpenTelemetry context. Until this issue is addressed
  131|       |    // (https://github.com/open-telemetry/opentelemetry-rust/issues/2877),
  132|       |    // filtering like this is the best way to suppress such logs.
  133|       |    //
  134|       |    // Note: This filtering will also drop logs from these components even when
  135|       |    // they are used outside of the OTLP Exporter.
  136|       |    const SUPPRESSED_CRATES: &[&str] = &[
  137|       |        "reqwest",
  138|       |        "tonic",
  139|       |        "tower",
  140|       |        "h2",
  141|       |        "hyper_util",
  142|       |        "opentelemetry_otlp",
  143|       |        "opentelemetry_sdk",
  144|       |    ];
  145|       |
  146|      1|    let add_common_filters = |filter: EnvFilter| -> EnvFilter {
  147|       |        SUPPRESSED_CRATES.iter().fold(filter, |f, crate_name| {
  148|       |            f.add_directive(format!("{crate_name}=off").parse().unwrap())
  149|       |        })
  150|       |    };
  151|       |
  152|      1|    let filter_otel = add_common_filters(make_filter());
  153|      1|    let otel_layer = otel_layer.with_filter(filter_otel);
  154|       |
  155|      1|    let filter_fmt =
  156|      1|        add_common_filters(make_filter()).add_directive("opentelemetry=off".parse().unwrap());
  157|      1|    let fmt_layer = tracing_subscriber::fmt::layer().with_filter(filter_fmt);
  158|       |
  159|      1|    let tracer = tracer_provider.tracer("tracing-otel-subscriber");
  160|       |
  161|       |    // Initialize the tracing subscriber with the OpenTelemetry layer and the
  162|       |    // Fmt layer.
  163|      1|    tracing_subscriber::registry()
  164|      1|        .with(otel_layer)
  165|      1|        .with(fmt_layer)
  166|       |        // .with(tracing_opentelemetry::MetricsLayer::new(
  167|       |        //     meter_provider.clone(),
  168|       |        // ))
  169|      1|        .with(tracing_opentelemetry::OpenTelemetryLayer::new(tracer))
  170|      1|        .init();
  171|       |
  172|      1|    OtelGuard {
  173|      1|        tracer_provider,
  174|      1|        meter_provider,
  175|      1|        logger_provider,
  176|      1|        endpoint_configured: endpoint_configured(),
  177|      1|    }
  178|      1|}
