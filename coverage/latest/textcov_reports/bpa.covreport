  216|       |                    Ok::<_, Error>(Some(StatusAssertion(None)))
  217|       |                } else {
  218|       |                    Ok(Some(StatusAssertion(Some(timestamp.into()))))
  219|       |                }
  220|       |            } else {
  221|       |                Ok(Some(StatusAssertion(None)))
  222|       |            }
  223|       |        } else {
