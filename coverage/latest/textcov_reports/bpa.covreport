   84|      2|    pub fn specificity_score(&self) -> Option<u32> {
   85|      2|        match self {
   86|      0|            DtnPatternItem::None => Some(256),
   87|      0|            DtnPatternItem::Any => Some(0),
   88|      0|            DtnPatternItem::Exact(node_name, service_name) => {
   89|      0|                Some(256 + node_name.len() as u32 + service_name.len() as u32)
   90|       |            }
   91|      2|            DtnPatternItem::Glob(pattern) => {
   92|      2|                let s = pattern.as_str();
   93|      2|                let authority = s.split('/').next().unwrap_or(s);
   94|       |
   95|       |                // Single wildcard constraint: at most one '*' in authority
   96|      2|                if authority.chars().filter(|&c| c == '*').count() > 1 {
   97|      0|                    return None;
   98|      2|                }
   99|       |
  100|       |                // Monotonic constraint: wildcard only in left-most label
  101|      2|                if authority.contains('*') {
  102|      0|                    let before_first_dot = authority.split('.').next().unwrap_or("");
  103|      0|                    if !before_first_dot.contains('*') {
  104|      0|                        return None; // wildcard not in leftmost label
  105|      0|                    }
  106|      2|                }
  107|       |
  108|      2|                let literal_len = s
  109|      2|                    .chars()
  110|      2|                    .filter(|c| !matches!(c, '*' | '?' | '[' | ']'))
  111|      2|                    .count() as u32;
  112|      2|                Some(literal_len)
  113|       |            }
  114|       |        }
  115|      2|    }
