  165|     40|            let data = Bytes::from(data);
  166|     40|            if !self.store.store(&mut bundle, &data).await {
  167|       |                // Duplicate status report - shouldn't happen but handle gracefully
  168|      0|                debug!("Duplicate status report bundle");
  169|      0|                return;
  170|     40|            }
  171|       |
  172|     40|            metrics::gauge!("bpa.bundle.status", "state" => crate::otel_metrics::status_label(&bundle.metadata.status)).increment(1.0);
  173|       |
  174|       |            // Dispatch via queue to avoid blocking the CLA session reader.
  175|       |            // Running inline would block incoming bundles on this connection
  176|       |            // for the duration of the status report's full pipeline.
  177|     40|            self.dispatch_bundle(bundle).await
  178|      0|        }
  179|     40|    }
