   69|      2|    fn cmp(&self, other: &Self) -> core::cmp::Ordering {
   70|       |        // Higher specificity score = Less (most specific patterns first in BTreeMap)
   71|      2|        let self_score = self.specificity_score().unwrap_or(0);
   72|      2|        let other_score = other.specificity_score().unwrap_or(0);
   73|      2|        other_score.cmp(&self_score).then_with(|| {
   74|       |            // Structural tiebreaker for equal scores
   75|       |            match (self, other) {
   76|       |                (EidPattern::Any, EidPattern::Any) => core::cmp::Ordering::Equal,
   77|       |                (EidPattern::Any, EidPattern::Set(_)) => core::cmp::Ordering::Less,
   78|       |                (EidPattern::Set(_), EidPattern::Any) => core::cmp::Ordering::Greater,
   79|       |                (EidPattern::Set(a), EidPattern::Set(b)) => a.cmp(b),
   80|       |            }
   81|       |        })
   82|      2|    }

