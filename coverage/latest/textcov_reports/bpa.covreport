_RNvNtNtNtCsgqvgc1imfVP_5tokio4loom3std3sys8num_cpus:
   85|      1|    pub(crate) fn num_cpus() -> usize {
   86|       |        use std::num::NonZeroUsize;
   87|       |
   88|       |        const ENV_WORKER_THREADS: &str = "TOKIO_WORKER_THREADS";
   89|       |
   90|      1|        match std::env::var(ENV_WORKER_THREADS) {
   91|      0|            Ok(s) => {
   92|      0|                let n = s.parse().unwrap_or_else(|e| {
   93|       |                    panic!("\"{ENV_WORKER_THREADS}\" must be usize, error: {e}, value: {s}")
   94|       |                });
   95|      0|                assert!(n > 0, "\"{ENV_WORKER_THREADS}\" cannot be set to 0");
   96|      0|                n
   97|       |            }
   98|       |            Err(std::env::VarError::NotPresent) => {
   99|      1|                std::thread::available_parallelism().map_or(1, NonZeroUsize::get)
  100|       |            }
  101|      0|            Err(std::env::VarError::NotUnicode(e)) => {
  102|      0|                panic!("\"{ENV_WORKER_THREADS}\" must be valid unicode, error: {e:?}")
  103|       |            }
  104|       |        }
  105|      1|    }
