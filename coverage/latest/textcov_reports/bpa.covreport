  195|      3|fn parse_regname(input: &mut &str) -> ModalResult<Box<str>> {
  196|      3|    take_while(0.., |c: char| {
  197|       |        c.is_alphanum()
  198|       |            || matches!(
  199|       |                c,
  200|       |                '-' | '.' | '_' | '~' | '!' | '$' | '&' | '\'' | '(' | ')' |
  201|       |                // '*' excluded: force a glob for node_names with *
  202|       |                '+' | ',' | ';' | '=' | '%'
  203|       |            )
  204|       |    })
  205|      3|    .try_map(|v| {
  206|       |        percent_decode_str(v)
  207|       |            .decode_utf8()
  208|       |            .map(|s| s.into_owned().into())
  209|       |    })
  210|      3|    .parse_next(input)
  211|      3|}
_RNvNtCs6YgCMbKxV7R_18hardy_eid_patterns11dtn_pattern14parse_dtn_glob:
  213|      1|fn parse_dtn_glob(input: &mut &str) -> ModalResult<DtnPatternItem> {
  214|       |    (
  215|      1|        terminated(
  216|      1|            take_while(0.., |c: char| {
  217|       |                c.is_alphanum()
  218|       |                    || matches!(
  219|       |                        c,
  220|       |                        '-' | '.'
  221|       |                            | '_'
  222|       |                            | '~'
  223|       |                            | '!'
  224|       |                            | '$'
  225|       |                            | '&'
  226|       |                            | '\''
  227|       |                            | '('
  228|       |                            | ')'
  229|       |                            | '*'
  230|       |                            | '+'
  231|       |                            | ','
  232|       |                            | ';'
  233|       |                            | '='
  234|       |                            | '['
  235|       |                            | '?'
  236|       |                            | '%'
  237|       |                    )
  238|       |            }),
  239|       |            "/",
  240|       |        ),
  241|      1|        take_while(0.., ('\x21'..='\x7b', /* No '|' (0x7c) */ '\x7d', '\x7e')),
  242|       |    )
  243|      1|        .try_map(|(node_name, demux)| {
  244|       |            DtnPatternItem::new_glob(&format!(
  245|       |                "{}/{}",
  246|       |                percent_decode_str(node_name)
  247|       |                    .decode_utf8()
  248|       |                    .map_err(|e| Error::ParseError(e.to_string()))?,
  249|       |                percent_decode_str(demux)
  250|       |                    .decode_utf8()
  251|       |                    .map_err(|e| Error::ParseError(e.to_string()))?
  252|       |            ))
  253|       |        })
  254|      1|        .parse_next(input)
  255|      1|}
_RNvNtCs6YgCMbKxV7R_18hardy_eid_patterns11dtn_pattern17parse_dtn_fullssp:
  169|      3|fn parse_dtn_fullssp(input: &mut &str) -> ModalResult<DtnPatternItem> {
  170|      3|    preceded("//", alt((parse_dtn_exact_ssp, parse_dtn_glob))).parse_next(input)
  171|      3|}
_RNvNtCs6YgCMbKxV7R_18hardy_eid_patterns11dtn_pattern18parse_dtn_pat_item:
  156|      3|pub(super) fn parse_dtn_pat_item(input: &mut &str) -> ModalResult<EidPatternItem> {
  157|      3|    preceded(
  158|       |        "dtn:",
  159|      3|        alt((
  160|      3|            "none".map(|_| EidPatternItem::DtnPatternItem(DtnPatternItem::None)),
  161|      3|            "**".map(|_| EidPatternItem::DtnPatternItem(DtnPatternItem::Any)),
  162|      3|            parse_dtn_fullssp.map(EidPatternItem::DtnPatternItem),
  163|       |        )),
  164|       |    )
  165|      3|    .parse_next(input)
  166|      3|}
_RNvNtCs6YgCMbKxV7R_18hardy_eid_patterns11dtn_pattern19parse_dtn_exact_ssp:
  174|      3|fn parse_dtn_exact_ssp(input: &mut &str) -> ModalResult<DtnPatternItem> {
  175|      3|    (
  176|      3|        terminated(parse_regname, "/"),
  177|      3|        take_while(0.., ('\x21'..='\x7b', /* No '|' (0x7c) */ '\x7d', '\x7e')),
  178|      3|    )
  179|      3|        .try_map(|(node_name, demux)| {
  180|       |            if demux.find(['?', '*', '[']).is_some() {
  181|       |                // Looks like a glob
  182|       |                DtnPatternItem::new_glob(&format!(
  183|       |                    "{node_name}/{}",
  184|       |                    percent_decode_str(demux)
  185|       |                        .decode_utf8()
  186|       |                        .map_err(|e| Error::ParseError(e.to_string()))?
  187|       |                ))
  188|       |            } else {
  189|       |                Ok(DtnPatternItem::Exact(node_name, demux.into()))
  190|       |            }
  191|       |        })
  192|      3|        .parse_next(input)
  193|      3|}
_RNvNtCs6YgCMbKxV7R_18hardy_eid_patterns11dtn_pattern7do_glob:
  257|  1.77k|fn do_glob(node_name: &str, demux: &str, pattern: &glob::Pattern) -> bool {
  258|  1.77k|    pattern.matches_with(
  259|  1.77k|        &format!("{node_name}//{demux}"),
  260|  1.77k|        glob::MatchOptions {
  261|  1.77k|            case_sensitive: false,
  262|  1.77k|            require_literal_separator: true,
  263|  1.77k|            require_literal_leading_dot: false,
  264|  1.77k|        },
  265|       |    )
