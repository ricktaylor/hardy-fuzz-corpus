  124|       |                // has already completed, e.g. if it was cancelled during
  125|       |                // shutdown. Consume the ref-count and return.
  126|       |                next.ref_dec();
  127|       |                if next.ref_count() == 0 {
  128|       |                    action = TransitionToRunning::Dealloc;
  129|       |                } else {
  130|       |                    action = TransitionToRunning::Failed;
  131|       |                }
