 1854|      1|        fn build_threaded_runtime(&mut self) -> io::Result<Runtime> {
 1855|       |            use crate::loom::sys::num_cpus;
 1856|       |            use crate::runtime::{Config, runtime::Scheduler};
 1857|       |            use crate::runtime::scheduler::{self, MultiThread};
 1858|       |
 1859|      1|            let worker_threads = self.worker_threads.unwrap_or_else(num_cpus);
 1860|       |
 1861|      1|            let (driver, driver_handle) = driver::Driver::new(self.get_cfg())?;
 1862|       |
 1863|       |            // Create the blocking pool
 1864|      1|            let blocking_pool =
 1865|      1|                blocking::create_blocking_pool(self, self.max_blocking_threads + worker_threads);
 1866|      1|            let blocking_spawner = blocking_pool.spawner().clone();
 1867|       |
 1868|       |            // Generate a rng seed for this runtime.
 1869|      1|            let seed_generator_1 = self.seed_generator.next_generator();
 1870|      1|            let seed_generator_2 = self.seed_generator.next_generator();
 1871|       |
 1872|      1|            let (scheduler, handle, launch) = MultiThread::new(
 1873|      1|                worker_threads,
 1874|      1|                driver,
 1875|      1|                driver_handle,
 1876|      1|                blocking_spawner,
 1877|      1|                seed_generator_2,
 1878|      1|                Config {
 1879|      1|                    before_park: self.before_park.clone(),
 1880|      1|                    after_unpark: self.after_unpark.clone(),
 1881|      1|                    before_spawn: self.before_spawn.clone(),
 1882|      1|                    #[cfg(tokio_unstable)]
 1883|      1|                    before_poll: self.before_poll.clone(),
 1884|      1|                    #[cfg(tokio_unstable)]
 1885|      1|                    after_poll: self.after_poll.clone(),
 1886|      1|                    after_termination: self.after_termination.clone(),
 1887|      1|                    global_queue_interval: self.global_queue_interval,
 1888|      1|                    event_interval: self.event_interval,
 1889|      1|                    #[cfg(tokio_unstable)]
 1890|      1|                    unhandled_panic: self.unhandled_panic.clone(),
 1891|      1|                    disable_lifo_slot: self.disable_lifo_slot,
 1892|      1|                    enable_eager_driver_handoff: self.enable_eager_driver_handoff,
 1893|      1|                    seed_generator: seed_generator_1,
 1894|      1|                    metrics_poll_count_histogram: self.metrics_poll_count_histogram_builder(),
 1895|      1|                },
 1896|      1|                self.timer_flavor,
 1897|      1|                self.name.clone(),
 1898|      1|            );
 1899|       |
 1900|      1|            let handle = Handle { inner: scheduler::Handle::MultiThread(handle) };
 1901|       |
 1902|       |            // Spawn the thread pool workers
 1903|      1|            let _enter = handle.enter();
 1904|      1|            launch.launch();
 1905|       |
 1906|      1|            Ok(Runtime::from_parts(Scheduler::MultiThread(scheduler), handle, blocking_pool))
 1907|      1|        }

