   27|      1|fn init_tracer(resource: &Resource) -> SdkTracerProvider {
   28|      1|    let exporter = opentelemetry_otlp::SpanExporter::builder()
   29|      1|        .with_tonic()
   30|      1|        .build()
   31|      1|        .expect("Failed to create span exporter");
   32|       |
   33|      1|    let tracer_provider = SdkTracerProvider::builder()
   34|       |        // Customize sampling strategy
   35|       |        // .with_sampler(Sampler::ParentBased(Box::new(Sampler::TraceIdRatioBased(
   36|       |        //     1.0,
   37|       |        // ))))
   38|       |        // If export trace to AWS X-Ray, you can use XrayIdGenerator
   39|       |        // .with_id_generator(RandomIdGenerator::default())
   40|      1|        .with_resource(resource.clone())
   41|      1|        .with_batch_exporter(exporter)
   42|      1|        .build();
   43|       |
   44|       |    // Set the global tracer provider using a clone of the tracer_provider.
   45|       |    // Setting global tracer provider is required if other parts of the application
   46|       |    // uses global::tracer() or global::tracer_with_version() to get a tracer.
   47|       |    // Cloning simply creates a new reference to the same tracer provider. It is
   48|       |    // important to hold on to the tracer_provider here, so as to invoke
   49|       |    // shutdown on it when application ends.
   50|      1|    global::set_tracer_provider(tracer_provider.clone());
   51|       |
   52|      1|    tracer_provider
   53|      1|}
