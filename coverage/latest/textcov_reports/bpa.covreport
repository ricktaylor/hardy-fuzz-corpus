   62|      0|        "gibibytes" => "GiBy".into(),
   63|      0|        "tebibytes" => "TiBy".into(),
   64|      0|        "bits_per_second" => "bit/s".into(),
   65|      0|        "kilobits_per_second" => "kbit/s".into(),
   66|      0|        "megabits_per_second" => "Mbit/s".into(),
   67|      0|        "gigabits_per_second" => "Gbit/s".into(),
   68|      0|        "terabits_per_second" => "Tbit/s".into(),
   69|      0|        "count_per_second" => "1/s".into(),
   70|      0|        other => other.into(),
