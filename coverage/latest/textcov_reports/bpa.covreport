  155|       |            // Ingress filters and go directly to routing.
  156|     40|            let mut bundle = bundle::Bundle {
  157|     40|                metadata: bundle::BundleMetadata {
  158|     40|                    status: bundle::BundleStatus::Dispatching,
  159|     40|                    ..Default::default()
  160|     40|                },
  161|     40|                bundle,
  162|     40|            };
