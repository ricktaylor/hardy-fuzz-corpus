  270|    999|    fn from_cbor(data: &[u8]) -> Result<(Self, bool, usize), Self::Error> {
  271|    999|        hardy_cbor::decode::parse_array(data, |a, s, tags| {
  272|       |            if !s || !tags.is_empty() {
  273|       |                return Err(Error::NotCanonical);
  274|       |            }
  275|       |            // Indefinite-length outer EID array: RFC-permitted but not
  276|       |            // canonical-shortest. The carry-through bool below picks
  277|       |            // this up so the returned `shortest` flag reflects it.
  278|       |            let canonical = a.is_definite();
  279|       |
  280|       |            let (scheme, s): (u64, bool) = a.parse().map_field_err::<Error>("EID scheme")?;
  281|       |            if !s {
  282|       |                return Err(Error::invalid_field(
  283|       |                    "EID scheme",
  284|       |                    Error::NotCanonical.into(),
  285|       |                ));
  286|       |            }
  287|       |
  288|       |            match scheme {
  289|       |                0 => Err(Error::UnsupportedScheme(0)),
  290|       |                1 => a
  291|       |                    .parse_value(|value, s, tags| {
  292|       |                        if !tags.is_empty() {
  293|       |                            return Err(Error::NotCanonical);
  294|       |                        }
  295|       |                        match value {
  296|       |                            hardy_cbor::decode::Value::UnsignedInteger(0) => {
  297|       |                                if !s {
  298|       |                                    return Err(Error::NotCanonical);
  299|       |                                }
  300|       |                                Ok((Eid::Null, canonical))
  301|       |                            }
  302|       |                            hardy_cbor::decode::Value::Text("none") => {
  303|       |                                if !s {
  304|       |                                    return Err(Error::NotCanonical);
  305|       |                                }
  306|       |                                // Non-canonical: §4.2.5.1.1 says uint 0.
  307|       |                                Ok((Eid::Null, false))
  308|       |                            }
  309|       |                            hardy_cbor::decode::Value::Text(text) => {
  310|       |                                if !s {
  311|       |                                    return Err(Error::NotCanonical);
  312|       |                                }
  313|       |                                parse_dtn
  314|       |                                    .parse(text)
  315|       |                                    .map(|e| (e, canonical))
  316|       |                                    .map_err(|e| Error::ParseError(e.to_string()))
  317|       |                            }
  318|       |                            hardy_cbor::decode::Value::TextStream(parts) => {
  319|       |                                // Indefinite-length text: RFC-permitted,
  320|       |                                // non-canonical.
  321|       |                                let combined = parts.iter().fold(String::new(), |mut acc, s| {
  322|       |                                    acc.push_str(s);
  323|       |                                    acc
  324|       |                                });
  325|       |                                parse_dtn
  326|       |                                    .parse(&combined)
  327|       |                                    .map(|e| (e, false))
  328|       |                                    .map_err(|e| Error::ParseError(e.to_string()))
  329|       |                            }
  330|       |                            value => Err(hardy_cbor::decode::Error::IncorrectType(
  331|       |                                "Untagged Text String or Unsigned Integer 0".to_string(),
  332|       |                                value.type_name(false),
  333|       |                            )
