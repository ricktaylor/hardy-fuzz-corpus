  325|       |                                parse_dtn
  326|       |                                    .parse(&combined)
  327|       |                                    .map(|e| (e, false))
  328|       |                                    .map_err(|e| Error::ParseError(e.to_string()))
  329|       |                            }
  330|       |                            value => Err(hardy_cbor::decode::Error::IncorrectType(
