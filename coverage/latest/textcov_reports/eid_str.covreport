 1406|      1|    let column = core::str::from_utf8(&input[line_start..=index])
 1407|      1|        .map(|s| s.chars().count() - 1)
 1408|      1|        .unwrap_or_else(|_| index - line_start);
 1409|      1|    let column = column + column_offset;
 1410|       |
 1411|      1|    (line, column)
